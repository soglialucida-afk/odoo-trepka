<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="booking_page" name="Rezervacija">
    <t t-call="website.layout">
      <t t-set="no_header" t-value="true"/>
      <t t-set="no_footer" t-value="true"/>
      <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #0d0d0d; color: #f0ede8; font-family: 'Georgia', serif; }
        .bk-header { background: #0d0d0d; padding: 20px 40px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #2a2a2a; }
        .bk-logo { color: #c9a84c; font-size: 1.4rem; letter-spacing: 3px; text-decoration: none; }
        .bk-back { color: #888; font-size: 0.85rem; text-decoration: none; letter-spacing: 1px; }
        .bk-back:hover { color: #c9a84c; }
        .bk-wrap { max-width: 680px; margin: 60px auto; padding: 0 24px 80px; }
        .bk-title { font-size: 2rem; color: #c9a84c; letter-spacing: 2px; margin-bottom: 8px; }
        .bk-sub { color: #888; font-size: 0.9rem; letter-spacing: 1px; margin-bottom: 48px; }
        .bk-section { margin-bottom: 40px; }
        .bk-label { display: block; font-size: 0.75rem; letter-spacing: 2px; color: #c9a84c; text-transform: uppercase; margin-bottom: 16px; }
        .service-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
        .service-card { border: 1px solid #2a2a2a; padding: 20px 12px; text-align: center; cursor: pointer; transition: all 0.2s; background: #111; }
        .service-card:hover { border-color: #c9a84c; }
        .service-card.active { border-color: #8b0000; background: #1a0a0a; }
        .service-name { font-size: 0.85rem; color: #f0ede8; margin-bottom: 6px; }
        .service-duration { font-size: 0.75rem; color: #888; letter-spacing: 1px; }
        .date-input { background: #111; border: 1px solid #2a2a2a; color: #f0ede8; padding: 14px 18px; font-size: 1rem; font-family: inherit; width: 100%; outline: none; }
        .date-input:focus { border-color: #c9a84c; }
        .date-hint { font-size: 0.75rem; color: #555; margin-top: 8px; }
        #slots-section { display: none; }
        .slots-grid { display: flex; flex-wrap: wrap; gap: 10px; }
        .slot-btn { border: 1px solid #2a2a2a; background: #111; color: #f0ede8; padding: 10px 20px; font-family: inherit; font-size: 0.9rem; cursor: pointer; letter-spacing: 1px; transition: all 0.2s; }
        .slot-btn:hover { border-color: #c9a84c; color: #c9a84c; }
        .slot-btn.active { background: #8b0000; border-color: #8b0000; color: #fff; }
        #slots-loading { color: #555; font-size: 0.85rem; display: none; }
        #slots-empty { color: #555; font-size: 0.85rem; display: none; }
        #contact-section { display: none; }
        .form-input { background: #111; border: 1px solid #2a2a2a; color: #f0ede8; padding: 14px 18px; font-size: 0.95rem; font-family: inherit; width: 100%; outline: none; margin-bottom: 14px; }
        .form-input:focus { border-color: #c9a84c; }
        textarea.form-input { resize: vertical; min-height: 100px; }
        .error-msg { background: #1a0000; border: 1px solid #8b0000; color: #ff6b6b; padding: 14px 18px; font-size: 0.85rem; margin-bottom: 24px; }
        .bk-submit { background: #8b0000; color: #fff; border: none; padding: 18px 48px; font-family: inherit; font-size: 0.85rem; letter-spacing: 3px; text-transform: uppercase; cursor: pointer; width: 100%; margin-top: 8px; }
        .bk-submit:hover { background: #a00000; }
        .summary-bar { background: #111; border: 1px solid #2a2a2a; padding: 16px 20px; margin-bottom: 32px; font-size: 0.85rem; color: #888; display: none; }
        .summary-bar span { color: #c9a84c; }
        @media (max-width: 600px) { .service-grid { grid-template-columns: 1fr; } .bk-title { font-size: 1.5rem; } }
      </style>

      <div class="bk-header">
        <a href="/" class="bk-logo">TM</a>
        <a href="/" class="bk-back">&#8592; Nazaj na stran</a>
      </div>

      <div class="bk-wrap">
        <h1 class="bk-title">Rezervacija termina</h1>
        <p class="bk-sub">Izberite storitev, datum in termin</p>

        <t t-if="error">
          <div class="error-msg"><t t-esc="error"/></div>
        </t>

        <form action="/rezervacija/submit" method="POST" id="booking-form">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
          <input type="hidden" name="time_slot" id="selected-slot-input"/>
          <input type="hidden" name="booking_date" id="booking-date-hidden"/>
          <input type="hidden" name="service" id="selected-service-input"/>

          <div class="bk-section">
            <span class="bk-label">01 &#8212; Storitev</span>
            <div class="service-grid">
              <label class="service-card" onclick="selectService(this, 'relax_45')">
                <div class="service-name">Relaxacijska masa&#382;a</div>
                <div class="service-duration">45 min</div>
              </label>
              <label class="service-card" onclick="selectService(this, 'swedish_60')">
                <div class="service-name">&#352;vedska masa&#382;a</div>
                <div class="service-duration">60 min</div>
              </label>
              <label class="service-card" onclick="selectService(this, 'sports_90')">
                <div class="service-name">&#352;portna masa&#382;a</div>
                <div class="service-duration">90 min</div>
              </label>
            </div>
          </div>

          <div class="bk-section" id="date-section" style="display:none">
            <span class="bk-label">02 &#8212; Datum</span>
            <input type="date" class="date-input" id="date-picker" onchange="onDateChange(this)"/>
            <p class="date-hint">Delamo ponedeljek&#8211;sobota</p>
          </div>

          <div class="bk-section" id="slots-section">
            <span class="bk-label">03 &#8212; Termin</span>
            <p id="slots-loading">Nalagam proste termine&#8230;</p>
            <p id="slots-empty">Za ta dan ni ve&#269; prostih terminov.</p>
            <div class="slots-grid" id="slots-grid"></div>
          </div>

          <div class="summary-bar" id="summary-bar">
            <span id="summary-text"></span>
          </div>

          <div class="bk-section" id="contact-section">
            <span class="bk-label">04 &#8212; Va&#353;i podatki</span>
            <input type="text" name="name" class="form-input" placeholder="Ime in priimek *" required="1"/>
            <input type="email" name="email" class="form-input" placeholder="E-mail *" required="1"/>
            <input type="tel" name="phone" class="form-input" placeholder="Telefon"/>
            <textarea name="notes" class="form-input" placeholder="Opombe (neobvezno)"></textarea>
            <button type="submit" class="bk-submit">Potrdi rezervacijo</button>
          </div>

        </form>
      </div>

      <script>
        var selectedService = null;
        var selectedDate = null;
        var selectedSlot = null;
        var serviceNames = {
          'relax_45': 'Relaxacijska masaza 45 min',
          'swedish_60': 'Svedska masaza 60 min',
          'sports_90': 'Sportna masaza 90 min'
        };

        function selectService(card, service) {
          document.querySelectorAll('.service-card').forEach(function(c) { c.classList.remove('active'); });
          card.classList.add('active');
          selectedService = service;
          document.getElementById('selected-service-input').value = service;
          document.getElementById('date-section').style.display = 'block';
          clearSlots();
          clearContact();
          updateSummary();
        }

        function onDateChange(input) {
          var val = input.value;
          if (!val) return;
          var d = new Date(val);
          if (d.getDay() === 0) {
            alert('Nedelja ni delovni dan. Prosimo izberite drug datum.');
            input.value = '';
            return;
          }
          selectedDate = val;
          document.getElementById('booking-date-hidden').value = val;
          loadSlots();
        }

        function loadSlots() {
          if (!selectedService || !selectedDate) return;
          var section = document.getElementById('slots-section');
          var grid = document.getElementById('slots-grid');
          var loading = document.getElementById('slots-loading');
          var empty = document.getElementById('slots-empty');
          section.style.display = 'block';
          loading.style.display = 'block';
          empty.style.display = 'none';
          grid.innerHTML = '';
          selectedSlot = null;
          document.getElementById('selected-slot-input').value = '';
          clearContact();
          fetch('/rezervacija/slots', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({jsonrpc: '2.0', method: 'call', id: 1, params: {date_str: selectedDate, service: selectedService}})
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            loading.style.display = 'none';
            var slots = (data.result || {}).slots || [];
            if (slots.length === 0) { empty.style.display = 'block'; return; }
            slots.forEach(function(slot) {
              var btn = document.createElement('button');
              btn.type = 'button';
              btn.className = 'slot-btn';
              btn.textContent = slot;
              btn.onclick = function() { selectSlot(btn, slot); };
              grid.appendChild(btn);
            });
          })
          .catch(function() { loading.style.display = 'none'; empty.style.display = 'block'; });
        }

        function selectSlot(btn, slot) {
          document.querySelectorAll('.slot-btn').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedSlot = slot;
          document.getElementById('selected-slot-input').value = slot;
          document.getElementById('contact-section').style.display = 'block';
          updateSummary();
        }

        function updateSummary() {
          var bar = document.getElementById('summary-bar');
          var txt = document.getElementById('summary-text');
          if (selectedService and selectedDate and selectedSlot) {
            bar.style.display = 'block';
            txt.innerHTML = '<span>' + serviceNames[selectedService] + '</span> | <span>' + selectedDate + '</span> | <span>' + selectedSlot + '</span>';
          } else {
            bar.style.display = 'none';
          }
        }

        function clearSlots() {
          document.getElementById('slots-section').style.display = 'none';
          document.getElementById('slots-grid').innerHTML = '';
          selectedSlot = null;
          document.getElementById('selected-slot-input').value = '';
        }

        function clearContact() {
          document.getElementById('contact-section').style.display = 'none';
        }

        var today = new Date().toISOString().split('T')[0];
        document.getElementById('date-picker').min = today;
      </script>

    </t>
  </template>

  <template id="booking_success" name="Rezervacija potrjena">
    <t t-call="website.layout">
      <t t-set="no_header" t-value="true"/>
      <t t-set="no_footer" t-value="true"/>
      <style>
        body { background: #0d0d0d; color: #f0ede8; font-family: 'Georgia', serif; }
        .bk-header { background: #0d0d0d; padding: 20px 40px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #2a2a2a; }
        .bk-logo { color: #c9a84c; font-size: 1.4rem; letter-spacing: 3px; text-decoration: none; }
        .success-wrap { max-width: 560px; margin: 80px auto; padding: 0 24px; text-align: center; }
        .success-icon { font-size: 3rem; margin-bottom: 24px; color: #c9a84c; }
        .success-title { font-size: 1.8rem; color: #c9a84c; letter-spacing: 2px; margin-bottom: 16px; }
        .success-detail { color: #888; font-size: 0.9rem; line-height: 1.8; margin-bottom: 40px; }
        .success-detail strong { color: #f0ede8; }
        .btn-home { display: inline-block; border: 1px solid #8b0000; color: #f0ede8; padding: 14px 40px; text-decoration: none; font-size: 0.8rem; letter-spacing: 3px; text-transform: uppercase; }
        .btn-home:hover { background: #8b0000; }
      </style>
      <div class="bk-header">
        <a href="/" class="bk-logo">TM</a>
      </div>
      <div class="success-wrap">
        <div class="success-icon">&#10003;</div>
        <h1 class="success-title">Rezervacija potrjena</h1>
        <p class="success-detail">
          <strong><t t-esc="booking_name"/></strong>, va&#353;a rezervacija je bila uspe&#353;no sprejeta.<br/>
          <strong><t t-esc="service_name"/></strong><br/>
          <strong><t t-esc="booking_date"/></strong> ob <strong><t t-esc="time_slot"/></strong><br/><br/>
          Potrditev prejmete na va&#353; e-mail naslov.
        </p>
        <a href="/" class="btn-home">Nazaj na stran</a>
      </div>
    </t>
  </template>

</odoo>
