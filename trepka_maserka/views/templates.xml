<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Skrij Odoo default header -->
  <record id="website.template_header_default" model="ir.ui.view">
    <field name="active" eval="False"/>
  </record>

  <record id="trepka_layout" model="ir.ui.view">
    <field name="name">trepka_maserka.layout</field>
    <field name="type">qweb</field>
    <field name="inherit_id" ref="website.layout"/>
    <field name="arch" type="xml">
      <xpath expr="//head" position="inside">
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&amp;family=Lato:wght@300;400;700&amp;display=swap" rel="stylesheet"/>
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet"/>
        <style>
body{font-family:'Lato',sans-serif;color:#3d1a0e;background:#f5ede0;overflow-x:hidden}
a{text-decoration:none;color:inherit}
.orn-rule{display:flex;align-items:center;justify-content:center;gap:12px;margin:14px 0}
.orn-rule::before,.orn-rule::after{content:"";flex:1;height:1px;background:#c4922a;max-width:70px}
.orn-diamond{width:7px;height:7px;background:#c4922a;transform:rotate(45deg);flex-shrink:0}
.orn-header{text-align:center;margin-bottom:48px}
.orn-header .eyebrow{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:#8a2926;display:block;margin-bottom:10px}
.orn-header h2{font-family:'Playfair Display',serif;font-style:italic;font-size:2.1rem;font-weight:400;color:#3d1a0e;margin:0}
.orn-header p{font-size:14px;color:#5a3e35;margin-top:12px;line-height:1.75}
.btn-tm-primary{display:inline-block;font-weight:700;letter-spacing:2px;font-size:11px;cursor:pointer;text-transform:uppercase;border-radius:0;background:#8a2926;color:white;padding:14px 38px;border:2px solid #8a2926;transition:background .25s}
.btn-tm-primary:hover{background:#6e1e1c;color:white}
.btn-tm-outline{display:inline-block;font-weight:700;letter-spacing:2px;font-size:11px;cursor:pointer;text-transform:uppercase;border-radius:0;background:transparent;color:#8a2926;padding:14px 34px;border:2px solid #8a2926;transition:background .25s,color .25s}
.btn-tm-outline:hover{background:#8a2926;color:white}
.tm-header{position:absolute;top:0;left:0;width:100%;z-index:1000;padding:22px 48px;transition:all .3s}
.tm-header.shrink{position:fixed;background:#fdf8f2;border-bottom:1px solid #c4a09a;padding:14px 48px}
.tm-header.shrink .tm-logo-text{color:#8a2926}
.tm-header.shrink .tm-logo-sub{color:#8a7068}
.tm-header.shrink .tm-nav a{color:#3d1a0e}
.tm-header.shrink .tm-nav a:hover{color:#8a2926}
.tm-header-inner{display:flex;justify-content:space-between;align-items:center;max-width:1300px;margin:0 auto}
.tm-logo-text{font-family:'Playfair Display',serif;font-style:italic;font-size:22px;color:white;letter-spacing:1px;transition:color .3s;line-height:1}
.tm-logo-sub{display:block;font-size:9px;letter-spacing:4px;text-transform:uppercase;color:rgba(255,255,255,.78);margin-top:3px}
.tm-nav ul{display:flex;list-style:none;gap:36px;margin:0;padding:0}
.tm-nav a{font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.88);transition:color .25s}
.tm-nav a:hover{color:#c4922a}
.tm-hero{position:relative;height:100vh;min-height:620px;overflow:hidden;background-color:#1e0d07}
.tm-slide{position:absolute;inset:0;opacity:0;transition:opacity 1.2s;background-size:cover;background-position:center;display:flex;align-items:center;justify-content:center;text-align:center;color:white}
.tm-slide.active{opacity:1;z-index:1}
.tm-slide-content{max-width:820px;padding:40px 20px;z-index:2}
.tm-slide-eyebrow{font-size:10px;letter-spacing:5px;text-transform:uppercase;color:rgba(255,255,255,.82);margin-bottom:20px;display:block}
.tm-slide-title{font-family:'Playfair Display',serif;font-style:italic;font-size:3.6rem;font-weight:400;line-height:1.2;margin:0}
.tm-slide-rule{display:flex;align-items:center;justify-content:center;gap:12px;margin:20px auto}
.tm-slide-rule::before,.tm-slide-rule::after{content:"";width:50px;height:1px;background:rgba(255,255,255,.35)}
.tm-slide-gem{width:6px;height:6px;background:rgba(232,200,122,.8);transform:rotate(45deg)}
.tm-slide-text{font-size:15px;margin-bottom:30px;color:rgba(255,255,255,.92);line-height:1.75}
.tm-section{padding:84px 0}
.tm-section-cream{background:#fdf8f2}
.tm-section-parchment{background:#f5ede0}
.tm-section-blush{background:#f7e6df}
.tm-section-dark{background:#1e0d07;color:#fdf8f2}
.tm-container{max-width:1200px;margin:0 auto;padding:0 24px}
.tm-services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px}
.tm-service-card{background:#fdf8f2;border:2px solid #8a2926;padding:3px;transition:transform .25s}
.tm-service-card:hover{transform:translateY(-5px)}
.tm-service-card-in{border:0.5px solid #c4a09a;padding:32px 24px 28px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px}
.tm-service-icon{width:90px;height:90px;border-radius:50%;background:white;border:1.5px solid #8a2926;display:flex;align-items:center;justify-content:center}
.tm-service-gem{width:9px;height:9px;background:#c4922a;transform:rotate(45deg)}
.tm-service-card h3{font-family:'Playfair Display',serif;font-style:italic;font-size:1.05rem;font-weight:400;color:#8a2926}
.tm-service-rule{width:28px;height:1px;background:#c4922a}
.tm-service-card p{font-size:14px;color:#5a3e35;line-height:1.75}
.tm-pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:20px}
.tm-price-card{background:#fdf8f2;border:2px solid #8a2926;padding:3px}
.tm-price-card-in{border:0.5px solid #c4a09a;padding:28px 24px 24px;display:flex;flex-direction:column;align-items:center;gap:10px}
.tm-price-card h3{font-family:'Playfair Display',serif;font-style:italic;font-size:1rem;font-weight:400;color:#8a2926}
.tm-price{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:#8a2926;line-height:1}
.tm-price small{font-size:1rem;font-weight:400}
.tm-price-card ul{list-style:none;font-size:13px;color:#5a3e35;line-height:2.1;width:100%;text-align:center;padding:0}
.tm-price-card ul li{border-bottom:0.5px solid #c4a09a;padding-bottom:2px}
.tm-price-card ul li:last-child{border-bottom:none}
.tm-price-rule{width:28px;height:1px;background:#c4922a}
.tm-testimonial-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px}
.tm-testimonial-item{border:1px solid rgba(196,146,42,.28);padding:3px}
.tm-testimonial-in{border:0.5px solid rgba(196,146,42,.14);padding:28px 24px}
.tm-testimonial-quote{font-size:48px;color:#c4922a;font-family:'Playfair Display',serif;line-height:.8;margin-bottom:12px;opacity:.65}
.tm-testimonial-item p{font-family:'Playfair Display',serif;font-style:italic;font-size:15px;line-height:1.8;color:rgba(253,248,242,.9)}
.tm-testimonial-item h4{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#c4922a;margin-top:18px}
.tm-footer{background:#150904;padding:56px 0 28px}
.tm-footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;padding-bottom:32px;border-bottom:1px solid rgba(196,146,42,.2)}
.tm-footer h3{font-family:'Playfair Display',serif;font-style:italic;font-size:1rem;color:#c4922a;font-weight:400;margin-bottom:14px}
.tm-footer p,.tm-footer a{font-size:13px;line-height:2.1;color:#9a8878}
.tm-footer a:hover{color:#c4922a}
.tm-social{display:flex;gap:16px;margin-top:4px}
.tm-social a{font-size:18px;color:#9a8878}
.tm-copyright{text-align:center;padding-top:24px;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(154,136,120,.6)}
.tm-book-tab{position:fixed;bottom:20px;right:20px;background:#8a2926;color:white;padding:13px 26px;font-weight:700;font-size:11px;letter-spacing:2px;text-transform:uppercase;z-index:999;cursor:pointer;border:1px solid rgba(255,255,255,.22);transition:background .25s;text-decoration:none;display:block}
.tm-book-tab:hover{background:#6e1e1c;color:white}
@media(max-width:768px){.tm-nav{display:none}.tm-slide-title{font-size:2.2rem}.tm-slide-eyebrow{display:none}.tm-header{padding:16px 20px}}
        </style>
      </xpath>
    </field>
  </record>

  <record id="trepka_homepage" model="ir.ui.view">
    <field name="name">trepka_maserka.homepage</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
      <t t-name="trepka_maserka.trepka_homepage">
        <t t-call="website.layout">
          <div id="wrap">

            <header class="tm-header" id="tm-header">
              <div class="tm-header-inner">
                <div><span class="tm-logo-text">Trepka Maserka<span class="tm-logo-sub">d.o.o. · Celje</span></span></div>
                <nav class="tm-nav">
                  <ul>
                    <li><a href="#tm-storitve">Storitve</a></li>
                    <li><a href="#tm-o-nas">O nas</a></li>
                    <li><a href="#tm-cenik">Cenik</a></li>
                    <li><a href="#tm-kontakt">Kontakt</a></li>
                  </ul>
                </nav>
              </div>
            </header>

            <section class="tm-hero">
              <div class="tm-slide active" style="background-image:linear-gradient(rgba(10,3,0,.42),rgba(10,3,0,.42)),url('/trepka_maserka/static/img/slika0.jpg');background-size:cover;background-position:center;">
                <div class="tm-slide-content">
                  <span class="tm-slide-eyebrow">Salon Trepka Maserka · Celje</span>
                  <h1 class="tm-slide-title">Frizerske &amp; Kozmeticne Storitve</h1>
                  <div class="tm-slide-rule"><div class="tm-slide-gem"></div></div>
                  <p class="tm-slide-text">Profesionalno strizenje, barvanje, nega obraza in telesa.</p>
                  <a href="/appointment" class="btn-tm-primary">Rezervirajte termin</a>
                </div>
              </div>
              <div class="tm-slide" style="background-image:linear-gradient(rgba(10,3,0,.48),rgba(10,3,0,.48)),url('/trepka_maserka/static/img/slika4.jpg');background-size:cover;background-position:center;">
                <div class="tm-slide-content">
                  <span class="tm-slide-eyebrow">Tradicija in kakovost</span>
                  <h1 class="tm-slide-title">Umetnost nege in sprostitve</h1>
                  <div class="tm-slide-rule"><div class="tm-slide-gem"></div></div>
                  <p class="tm-slide-text">Strokovno osebje, topel sprejem, nepozabna izkusnja.</p>
                  <a href="/appointment" class="btn-tm-outline" style="color:white;border-color:rgba(255,255,255,.65);">Prijavite se zdaj</a>
                </div>
              </div>
            </section>

            <section id="tm-storitve" class="tm-section tm-section-parchment oe_structure oe_empty">
              <div class="tm-container">
                <div class="orn-header">
                  <span class="eyebrow">Kar ponujamo</span>
                  <div class="orn-rule"><div class="orn-diamond"></div></div>
                  <h2>Nase storitve</h2>
                  <p>Sirok nabor frizerskih in kozmeticnih tretmajev, prilagojenih vam.</p>
                </div>
                <div class="tm-services-grid">
                  <div class="tm-service-card"><div class="tm-service-card-in">
                    <div class="tm-service-icon"><i class="fas fa-star" style="font-size:32px;color:#8a2926;"></i></div>
                    <div class="tm-service-gem"></div><h3>Depilacija z voskom</h3>
                    <div class="tm-service-rule"></div>
                    <p>Topel in hladni vosek za obcutljive predele. Hitro, ucinkovito in udobno.</p>
                  </div></div>
                  <div class="tm-service-card"><div class="tm-service-card-in">
                    <div class="tm-service-icon"><i class="fas fa-spa" style="font-size:32px;color:#8a2926;"></i></div>
                    <div class="tm-service-gem"></div><h3>Nega obraza</h3>
                    <div class="tm-service-rule"></div>
                    <p>Individualni pristop za vsak tip koze. Od anti-age do aknaste koze.</p>
                  </div></div>
                  <div class="tm-service-card"><div class="tm-service-card-in">
                    <div class="tm-service-icon"><i class="fas fa-cut" style="font-size:32px;color:#8a2926;"></i></div>
                    <div class="tm-service-gem"></div><h3>Threading</h3>
                    <div class="tm-service-rule"></div>
                    <p>Natancno oblikovanje obrvi z nitko. Tudi sprehodi brez narocila.</p>
                  </div></div>
                  <div class="tm-service-card"><div class="tm-service-card-in">
                    <div class="tm-service-icon"><i class="fas fa-hand-sparkles" style="font-size:32px;color:#8a2926;"></i></div>
                    <div class="tm-service-gem"></div><h3>Manikura in pedikura</h3>
                    <div class="tm-service-rule"></div>
                    <p>OPI in Artistic laki, geliranje, IBX tretma za krepitev nohtov.</p>
                  </div></div>
                </div>
              </div>
            </section>

            <section id="tm-cenik" class="tm-section tm-section-cream oe_structure oe_empty">
              <div class="tm-container">
                <div class="orn-header">
                  <span class="eyebrow">Storitve po meri</span>
                  <div class="orn-rule"><div class="orn-diamond"></div></div>
                  <h2>Cenik</h2>
                  <p>Strizenje, tretmaji, masaze, nohti - vse na enem mestu.</p>
                </div>
                <div class="tm-pricing-grid">
                  <div class="tm-price-card"><div class="tm-price-card-in">
                    <div class="tm-price">od <small>EUR</small>28</div><div class="tm-price-rule"></div>
                    <h3>Strizenje las</h3>
                    <ul><li>Posvet</li><li>Pranje + masaza glave</li><li>Strizenje</li><li>Oblikovanje s fenom</li></ul>
                  </div></div>
                  <div class="tm-price-card"><div class="tm-price-card-in">
                    <div class="tm-price">od <small>EUR</small>15</div><div class="tm-price-rule"></div>
                    <h3>Tretmaji za lase</h3>
                    <ul><li>Olaplex zascita</li><li>Marosko olje</li><li>Keratinsko ravnanje</li></ul>
                  </div></div>
                  <div class="tm-price-card"><div class="tm-price-card-in">
                    <div class="tm-price">od <small>EUR</small>15</div><div class="tm-price-rule"></div>
                    <h3>Masaze</h3>
                    <ul><li>Stol masaza</li><li>Svedska + vroci kamni</li><li>Sportna masaza</li></ul>
                  </div></div>
                  <div class="tm-price-card"><div class="tm-price-card-in">
                    <div class="tm-price">od <small>EUR</small>15</div><div class="tm-price-rule"></div>
                    <h3>Nega nohtov</h3>
                    <ul><li>Oblikovanje in lak</li><li>OPI gel lak</li><li>Manikura / Pedikura</li></ul>
                  </div></div>
                </div>
              </div>
            </section>

            <section class="tm-section tm-section-dark oe_structure oe_empty">
              <div class="tm-container">
                <div style="text-align:center;margin-bottom:48px;">
                  <h2 style="font-family:'Playfair Display',serif;font-style:italic;font-size:2rem;font-weight:400;color:#fdf8f2;">Kaj pravijo nase stranke</h2>
                </div>
                <div class="tm-testimonial-grid">
                  <div class="tm-testimonial-item"><div class="tm-testimonial-in">
                    <div class="tm-testimonial-quote">"</div>
                    <p>Najboljsa izkusnja s strizenjem in poudarki. Prijazno osebje, definitivno se vracam.</p>
                    <h4>- Maja K.</h4>
                  </div></div>
                  <div class="tm-testimonial-item"><div class="tm-testimonial-in">
                    <div class="tm-testimonial-quote">"</div>
                    <p>Depilacija je bila hitra in brez bolecin. Ze leta sem zvesta stranka.</p>
                    <h4>- Ana P.</h4>
                  </div></div>
                  <div class="tm-testimonial-item"><div class="tm-testimonial-in">
                    <div class="tm-testimonial-quote">"</div>
                    <p>Odlicna masaza, sprostila sem se po dolgem casu. Priporocam vsem.</p>
                    <h4>- Marko Z.</h4>
                  </div></div>
                </div>
              </div>
            </section>

            <footer class="tm-footer" id="tm-kontakt">
              <div class="tm-container">
                <div class="tm-footer-grid">
                  <div>
                    <h3>Trepka Maserka d.o.o.</h3>
                    <p>Kosovelova ulica 7<br/>3000 Celje, Slovenija</p>
                    <p style="margin-top:10px;"><a href="tel:+38634567890">+386 (0)3 456 7890</a><br/><a href="mailto:info@trepka-maserka.si">info@trepka-maserka.si</a></p>
                  </div>
                  <div>
                    <h3>Delovni cas</h3>
                    <p>Pon-Pet: 9:00-20:00<br/>Sobota: 9:00-15:00<br/>Nedelja: Zaprto</p>
                  </div>
                  <div>
                    <h3>Sledite nam</h3>
                    <div class="tm-social">
                      <a href="#"><i class="fab fa-facebook"></i></a>
                      <a href="#"><i class="fab fa-instagram"></i></a>
                    </div>
                  </div>
                </div>
                <div class="tm-copyright"><p>2025 - Trepka Maserka - Vse pravice pridrzane</p></div>
              </div>
            </footer>

            <a href="/appointment" class="tm-book-tab">Rezervirajte termin</a>

            <script type="text/javascript">
(function() {
    function init() {
        var slides = document.querySelectorAll('.tm-slide');
        if (!slides.length) return;
        var cur = 0;
        setInterval(function() {
            slides[cur].classList.remove('active');
            cur = (cur + 1) % slides.length;
            slides[cur].classList.add('active');
        }, 5000);
        var header = document.querySelector('.tm-header');
        if (header) {
            window.addEventListener('scroll', function() {
                header.classList.toggle('shrink', window.scrollY > 50);
            });
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
            </script>

          </div>
        </t>
      </t>
    </field>
  </record>

</odoo>