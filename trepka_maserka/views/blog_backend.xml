<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="trepka_blog_post_form" model="ir.ui.view">
    <field name="name">trepka.blog.post.form</field>
    <field name="model">trepka.blog.post</field>
    <field name="arch" type="xml">
      <form string="Blog objava">
        <sheet>
          <group>
            <field name="name" placeholder="Naslov objave"/>
            <field name="slug" placeholder="url-slug-objave"/>
            <field name="subtitle" placeholder="Kratek podnaslov"/>
            <field name="author"/>
            <field name="category"/>
            <field name="date_published"/>
            <field name="is_published"/>
          </group>
          <group>
            <field name="meta_description" placeholder="SEO opis (max 160 znakov)"/>
          </group>
          <group string="Naslovna slika">
            <field name="image" widget="image"/>
          </group>
          <group string="Vsebina">
            <field name="body" widget="text" nolabel="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="trepka_blog_post_list" model="ir.ui.view">
    <field name="name">trepka.blog.post.list</field>
    <field name="model">trepka.blog.post</field>
    <field name="arch" type="xml">
      <list string="Blog objave">
        <field name="name"/>
        <field name="category"/>
        <field name="author"/>
        <field name="date_published"/>
        <field name="is_published"/>
      </list>
    </field>
  </record>

  <record id="trepka_blog_post_action" model="ir.actions.act_window">
    <field name="name">Blog objave</field>
    <field name="res_model">trepka.blog.post</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="trepka_blog_menu_root"
    name="Blog"
    sequence="10"/>

  <menuitem id="trepka_blog_menu_posts"
    name="Objave"
    parent="trepka_blog_menu_root"
    action="trepka_blog_post_action"
    sequence="1"/>

</odoo>